<UserControl x:Class="AIHub.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>

        <!-- CREATE MODE -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Create Project" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

            <TextBlock Text="Project Name" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding NewProject.Name}" Margin="0,4,0,12" />

            <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding NewProject.Description}" Margin="0,4,0,12" AcceptsReturn="True" Height="120" TextWrapping="Wrap"/>

            <Button Content="Create"
                    Command="{Binding CreateProjectCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="120"/>

        </StackPanel>


        <!-- EDIT MODE -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="Edit Project" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

            <TextBlock Text="Project Name" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding SelectedProject.Name}" Margin="0,4,0,12" />

            <TextBlock Text="Description" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding SelectedProject.Description}" Margin="0,4,0,12" AcceptsReturn="True" Height="120" TextWrapping="Wrap"/>

            <Button Content="Save"
                    Command="{Binding UpdateProjectCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="120"/>

        </StackPanel>

    </Grid>
</UserControl>
