<UserControl x:Class="AIHub.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Margin="32" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="My Profile" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Manage your account details and preferences." Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Status message -->
            <Border Background="#204A90E2" BorderThickness="1" BorderBrush="#4A90E2" CornerRadius="6" Padding="12" Margin="0,0,0,20"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#4A90E2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Border>

            <!-- Avatar + Identity card -->
            <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar circle -->
                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40" Background="{StaticResource PrimaryBrush}" Margin="0,0,24,0">
                        <Grid>
                            <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"
                                   Visibility="{Binding AvatarUrl, Converter={StaticResource StringToVisibilityConverter}}" />
                            <TextBlock Text="{Binding Initials}" FontSize="28" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Profile info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding Email}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                        <Border Background="#1A137fec" CornerRadius="4" Padding="8,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>
                        <Button Content="Change Avatar" Command="{Binding SelectAvatarCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="8" Margin="0,12,0,0" Width="140" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SelectedAvatarPath}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" Visibility="{Binding SelectedAvatarPath, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Edit profile card -->
            <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Edit Profile" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="Display Name" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}"
                             BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Padding="10,8" Margin="0,0,0,16">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Email Address" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Email}" IsReadOnly="True"
                             Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextMutedBrush}"
                             BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Padding="10,8" Margin="0,0,0,24">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Content="Save Changes" Command="{Binding SaveProfileCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"
                            HorizontalAlignment="Left" IsEnabled="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>
                </StackPanel>
            </Border>

            <!-- Danger zone -->
            <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="#7f1d1d"
                    CornerRadius="12" Padding="24">
                <StackPanel>
                    <TextBlock Text="Account Actions" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Logging out will end your current session." FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"/>
                    <Button Content="🚪  Log Out" Command="{Binding LogoutCommandCommand}"
                            Background="#7f1d1d" Foreground="White" BorderThickness="0"
                            Padding="20,10" HorizontalAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#991b1b"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
