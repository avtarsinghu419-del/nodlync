<Window x:Class="AIHub.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIHub.Views"
        xmlns:vm="clr-namespace:AIHub.ViewModels"
        Title="NodLync" Height="850" Width="1300"
        Icon="/AIHub;component/LOGO/favicon.ico"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectsViewModel}"><views:ProjectsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectWorkspaceViewModel}"><views:ProjectWorkspacePage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ApiVaultViewModel}"><views:ApiVaultPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ApiTesterViewModel}"><views:ApiTesterPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkflowsViewModel}"><views:WorkflowsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MeetingsViewModel}"><views:MeetingsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}"><views:LogsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:IdeasLabViewModel}"><views:IdeasLabPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><views:LoginPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}"><views:RegisterPage /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}"><views:ProfilePage /></DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border x:Name="SidebarBorder"
                Background="{StaticResource SidebarBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}"
                IsEnabled="{Binding IsAuthenticated}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Effect" Value="{x:Null}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="8" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24">
                    <Image Source="/AIHub;component/LOGO/favicon-96x96.png" Width="36" Height="36" Stretch="Uniform" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="NodLync" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Workspace" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1" Margin="14,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Navigation Items mapped directly via CommandParameters -->
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE9D2;" Margin="0,0,8,0"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Projects">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7C3;" Margin="0,0,8,0"/>
                                <TextBlock Text="Projects"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="ApiVault">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE72E;" Margin="0,0,8,0"/>
                                <TextBlock Text="API Vault"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="ApiTester">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE943;" Margin="0,0,8,0"/>
                                <TextBlock Text="API Tester"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="IdeasLab">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE7BE;" Margin="0,0,8,0"/>
                                <TextBlock Text="AI Playground"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Workflows">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEADF;" Margin="0,0,8,0"/>
                                <TextBlock Text="Workflows"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Meetings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8A7;" Margin="0,0,8,0"/>
                                <TextBlock Text="Meetings"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Logs">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE9D9;" Margin="0,0,8,0"/>
                                <TextBlock Text="Logs"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Reports">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE9D5;" Margin="0,0,8,0"/>
                                <TextBlock Text="Reports"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" Margin="0,0,8,0"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Profile">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE77B;" Margin="0,0,8,0"/>
                                <TextBlock Text="Profile"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- User profile (clickable → Profile page) -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}" Padding="20" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Profile"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource PrimaryBrush}" Width="32" Height="32" CornerRadius="16">
                            <Grid>
                                <Image Source="{Binding SidebarUserAvatarUrl}" Stretch="UniformToFill" 
                                       Visibility="{Binding SidebarUserAvatarUrl, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding SidebarUserInitials}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SidebarUserAvatarUrl}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="{Binding SidebarUserName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="{Binding SidebarUserRole}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border x:Name="HeaderBorder"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource BackgroundBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect" Value="{x:Null}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect Radius="8" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="24,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageTitle}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="16,0"/>
                        <Button Content="+ New Project"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12"
                                Command="{Binding QuickCreateProjectCommand}"
                                IsEnabled="{Binding IsAuthenticated}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Search with global search command -->
                        <Grid>
                            <TextBox x:Name="SearchBox" Width="250" Background="{StaticResource CardBrush}" 
                                     Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" Padding="10,8" Margin="0,0,16,0"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                                <TextBox.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>
                        <TextBlock Text="🔔" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0" Cursor="Hand"/>
                        <TextBlock Text="❓" FontSize="18" VerticalAlignment="Center" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Health Warning Banner (row 1, Auto height) -->
            <Border Grid.Row="1" Background="#33FFCC00" BorderBrush="#FFFFCC00" BorderThickness="0,0,0,1"
                    Visibility="{Binding HealthWarning, Converter={StaticResource StringToVisibilityConverter}}"
                    Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="âš  " Foreground="#FFFFCC00" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding HealthWarning}" Foreground="#FFFFCC00" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Dynamic Content Area -->
            <ContentControl Grid.Row="2"
                            Content="{Binding CurrentViewModel}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>

        </Grid>
    </Grid>
</Window>
